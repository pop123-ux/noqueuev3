      ]
    },
    {
      "entity_name": "Case",
      "allowed_operations": [
        "read",
        "create",
        "update"
      ]
    },
    {
      "function_name": "saveImmigrationProfile",
      "description": "Create or update the user's ImmigrationProfile (country, purpose, city, housing, contract, etc.)."
    },
    {
      "function_name": "generateIntegrationChecklist",
      "description": "Generate a personalized list of relocation tasks based on the user's ImmigrationProfile."
    },
    {
      "function_name": "findNearbyInstitutions",
      "description": "Look up Romanian public-service offices (IGI, CAS, ANAF, civil registry, etc.) by city and type."
    }
  ],
